{
  "manifest_version": 3,
  "name": "Link Sanitizer",
  "version": "0.2.1",
  "description": "Cleans links on hover via linkcleaner.app before you click them.",
  "permissions": ["storage"],
  "host_permissions": ["https://slashcopy.com/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/link-sanitizer-icon-16.png",
    "32": "icons/link-sanitizer-icon-32.png",
    "48": "icons/link-sanitizer-icon-48.png",
    "128": "icons/link-sanitizer-icon-128.png"
  }
}
